rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'dadakhalander34@gmail.com';
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function isValidShift(data) {
      return data.userId == request.auth.uid 
        && data.date is string 
        && data.startTime is string 
        && data.endTime is string
        && (data.sector == null || data.sector is string)
        && data.keys().hasAll(['userId', 'date', 'startTime', 'endTime', 'createdAt']);
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /logs/{logId} {
      allow read, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /schedules/{shiftId} {
      allow read, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidShift(request.resource.data);
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin()) && isValidShift(request.resource.data);
    }

    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
